# === ОБЯЗАТЕЛЬНЫЕ ===

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# API-ключ для LLM (любой OpenAI-совместимый провайдер)
LLM_API_KEY=your_api_key_here

# === ОПЦИОНАЛЬНЫЕ (есть значения по умолчанию) ===

# URL провайдера LLM (OpenAI-совместимый API)
LLM_BASE_URL=https://api.openai.com/v1

# Быстрая/дешёвая модель для оценки релевантности (вызывается ~30 раз за дайджест)
LLM_SCORING_MODEL=gpt-4o-mini

# Умная модель для генерации обзоров (вызывается 3 раза за дайджест)
LLM_GENERATION_MODEL=google/gemini-2.5-flash
